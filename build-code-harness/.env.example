# The model every agent and the manager use. Any LiteLLM-supported model
# string works; this project was built and tested against Claude via
# OpenRouter.
MODEL="openrouter/anthropic/claude-sonnet-4-6"
OPENROUTER_API_KEY=""

# Required. E2BExecTool and E2BPythonTool have no unsandboxed fallback --
# without this key, the sandbox tools (and run_tests, which is routed
# through them) are never defined.
E2B_API_KEY=""

# Required only because memory=True is on. CrewAI's default memory embedder
# is OpenAI's text-embedding-3-large, independent of MODEL above. Not read
# anywhere else in this project. Leave blank and set memory=False in
# deep_agent_crew.py, or configure a non-OpenAI embedder, if you'd rather
# not add a second provider.
OPENAI_API_KEY=""